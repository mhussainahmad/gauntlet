<mujoco model="gauntlet_tabletop">
  <option integrator="implicitfast" timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="512"/>
    <material name="table_mat"    rgba="0.7 0.5 0.3 1"/>
    <material name="cube_mat"     rgba="0.8 0.2 0.2 1"/>
    <material name="cube_alt_mat" rgba="0.2 0.6 0.2 1"/>
    <material name="ee_mat"       rgba="0.2 0.6 0.9 1"/>
    <material name="target_mat"   rgba="0.2 0.9 0.2 0.5"/>
    <material name="distractor_mat" rgba="0.4 0.4 0.8 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="1 1 1"/>

    <camera name="main" pos="0.6 -0.6 0.8" xyaxes="1 1 0 0 0 1"/>

    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.3 0.3 0.3 1"/>

    <body name="table" pos="0 0 0.4">
      <geom name="table_top" type="box" size="0.5 0.5 0.02" material="table_mat"/>
    </body>

    <body name="cube" pos="0 0 0.47">
      <freejoint/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025"
            material="cube_mat" mass="0.1"/>
      <!-- B-06 object-swap alternates. Co-resident inside the cube body
           so the freejoint, the cached body id, and the grasp / success
           geometry all stay valid across class swaps. Each is hidden
           (alpha=0, contype=0, conaffinity=0) at scene-load time;
           ``set_perturbation('object_swap', i)`` reveals the matching
           geom and hides the cube. Footprints match the cube's grasp
           radius (0.025 m) so swap classes are interchangeable from the
           scripted policy's perspective. Geoms mirror the per-class
           MJCF snippets shipped under ``assets/objects/`` for
           single-source-of-truth documentation. -->
      <geom name="swap_mug_geom" type="cylinder" size="0.025 0.025"
            rgba="0.95 0.92 0.85 0" mass="0.1"
            contype="0" conaffinity="0"/>
      <geom name="swap_banana_geom" type="capsule" size="0.018 0.04"
            rgba="0.95 0.85 0.15 0" mass="0.1"
            contype="0" conaffinity="0"/>
      <geom name="swap_screwdriver_geom" type="cylinder" size="0.012 0.05"
            rgba="0.55 0.55 0.6 0" mass="0.1"
            contype="0" conaffinity="0"/>
      <geom name="swap_bottle_geom" type="ellipsoid" size="0.022 0.022 0.045"
            rgba="0.15 0.25 0.65 0" mass="0.1"
            contype="0" conaffinity="0"/>
    </body>

    <body name="ee" mocap="true" pos="0 0 0.7">
      <geom name="ee_geom" type="sphere" size="0.02" material="ee_mat"
            contype="0" conaffinity="0"/>
    </body>

    <site name="target" pos="0.2 0.1 0.42" size="0.05 0.05 0.001"
          type="cylinder" material="target_mat"/>

    <!-- Distractor slots: 10 boxes laid out around the table edge.
         All start invisible (alpha=0) and non-colliding (contype=0,
         conaffinity=0). DistractorCount.set_perturbation enables the
         first N by setting alpha=1 and restoring contype/conaffinity=1. -->
    <body name="distractor_0" pos="0.35 0.0 0.435">
      <geom name="distractor_0_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_1" pos="-0.35 0.0 0.435">
      <geom name="distractor_1_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_2" pos="0.0 0.35 0.435">
      <geom name="distractor_2_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_3" pos="0.0 -0.35 0.435">
      <geom name="distractor_3_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_4" pos="0.3 0.3 0.435">
      <geom name="distractor_4_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_5" pos="-0.3 0.3 0.435">
      <geom name="distractor_5_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_6" pos="0.3 -0.3 0.435">
      <geom name="distractor_6_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_7" pos="-0.3 -0.3 0.435">
      <geom name="distractor_7_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_8" pos="0.42 0.15 0.435">
      <geom name="distractor_8_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
    <body name="distractor_9" pos="-0.42 -0.15 0.435">
      <geom name="distractor_9_geom" type="box" size="0.015 0.015 0.015"
            material="distractor_mat" rgba="0.4 0.4 0.8 0"
            contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
