<mujoco model="gauntlet_tabletop_stack">
  <!-- B-09 stub — long-horizon stacking env. Three coloured cubes on a
       table top, one mocap end-effector. No distractor slots, no target
       site, no perturbation hooks: this is the minimum scene that
       supports a 3-step skill-chain (pick A, place on B, pick C, place
       on stack). Asset deliberately mirrors `tabletop.xml`'s units,
       table-top dimensions, integrator timestep, and mocap pattern so
       the same grasp / mocap conventions transfer without surprise.
       Cube half-extent is 0.025 m to match the source env. -->
  <option integrator="implicitfast" timestep="0.01" gravity="0 0 -9.81"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="512"/>
    <material name="table_mat" rgba="0.7 0.5 0.3 1"/>
    <material name="cube_a_mat" rgba="0.85 0.18 0.18 1"/>
    <material name="cube_b_mat" rgba="0.18 0.7 0.25 1"/>
    <material name="cube_c_mat" rgba="0.18 0.32 0.85 1"/>
    <material name="ee_mat" rgba="0.2 0.6 0.9 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 2" dir="0 0 -1" diffuse="1 1 1"/>

    <camera name="main" pos="0.6 -0.6 0.8" xyaxes="1 1 0 0 0 1"/>

    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.3 0.3 0.3 1"/>

    <body name="table" pos="0 0 0.4">
      <geom name="table_top" type="box" size="0.5 0.5 0.02" material="table_mat"/>
    </body>

    <!-- Three free-floating coloured cubes laid out at deterministic
         starting positions spaced ~0.2 m apart along Y. Same half-extent
         (0.025 m) as the source TabletopEnv so grasp tolerances carry
         across without retuning. The reset() routine in the env may
         shift these per-seed but starts from these baseline poses. -->
    <body name="cube_a" pos="0.0 -0.2 0.47">
      <freejoint/>
      <geom name="cube_a_geom" type="box" size="0.025 0.025 0.025"
            material="cube_a_mat" mass="0.1"/>
    </body>

    <body name="cube_b" pos="0.0 0.0 0.47">
      <freejoint/>
      <geom name="cube_b_geom" type="box" size="0.025 0.025 0.025"
            material="cube_b_mat" mass="0.1"/>
    </body>

    <body name="cube_c" pos="0.0 0.2 0.47">
      <freejoint/>
      <geom name="cube_c_geom" type="box" size="0.025 0.025 0.025"
            material="cube_c_mat" mass="0.1"/>
    </body>

    <body name="ee" mocap="true" pos="0 0 0.7">
      <geom name="ee_geom" type="sphere" size="0.02" material="ee_mat"
            contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
