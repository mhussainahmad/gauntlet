<!DOCTYPE html>
{# Gauntlet failure-analysis report.

Design rules from GAUNTLET_SPEC.md §6:
* "Never aggregate away failures." The failure-clusters table leads the
  report; the overall success rate is NEVER headlined above it. The
  summary card's primary number is the failure rate + pass/fail dot.
* "No wall-of-numbers reports." The per-cell table is collapsed inside
  a <details> block — available but not in the way.

Data-embed conventions:
* `data` is ``report.model_dump(mode="json")`` with NaN → null applied
  recursively in ``gauntlet.report.html`` (kept OUT of the template so
  a rendered page always parses as valid JSON on the JS side).
* ``model_dump(mode="json")`` stringifies float dict keys; JS calls
  ``parseFloat`` on the way back out (see ``renderAxisCharts`` etc.).
#}
<html lang="en">
<head>
<meta charset="utf-8">
<title>Gauntlet report — {{ report.suite_name }}</title>
<style>
  :root {
    --fg: #1a1a1a;
    --fg-muted: #555;
    --bg: #fafafa;
    --card-bg: #ffffff;
    --border: #e1e1e1;
    --pass: #2ca02c;
    --fail: #d62728;
    --warn: #f0ad4e;
    --heat-good: #2ca02c;
    --heat-bad: #d62728;
    --heat-none: #d0d0d0;
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                 "Helvetica Neue", Arial, sans-serif;
    color: var(--fg);
    background: var(--bg);
    margin: 0;
    padding: 24px;
    line-height: 1.4;
  }
  h1, h2, h3 { margin: 0 0 8px; }
  h1 { font-size: 1.6rem; }
  h2 { font-size: 1.25rem; margin-top: 32px; }
  h3 { font-size: 1.0rem; font-weight: 600; }
  section { margin-bottom: 24px; }
  .card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
  }
  .summary {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 16px 24px;
    align-items: center;
  }
  .summary-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid rgba(0, 0, 0, 0.15);
  }
  .summary-dot.pass { background: var(--pass); }
  .summary-dot.fail { background: var(--fail); }
  .summary-dot.warn { background: var(--warn); }
  .summary-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 20px 32px;
  }
  .metric-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }
  .metric-value { font-size: 1.5rem; font-weight: 600; }
  .metric-value.fail { color: var(--fail); }
  .subtle { color: var(--fg-muted); font-size: 0.9rem; }
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.9rem;
  }
  th, td {
    border-bottom: 1px solid var(--border);
    padding: 6px 10px;
    text-align: left;
    vertical-align: top;
  }
  th { background: #f0f0f0; font-weight: 600; }
  tbody tr:hover { background: #fafafa; }
  td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
  /* B-03: Wilson 95% CI bracket sits next to the rate it qualifies, in
     low-chroma Gravel so the rate stays the loud number and the bracket
     reads as the modifier it is. Tabular numerals so a column of
     brackets line up vertically (DESIGN.md Tabular Numerals Rule).
     Slightly smaller than body so the bracket never out-shouts the
     point estimate it qualifies. ``white-space: nowrap`` keeps the
     bracket from wrapping mid-pair on a narrow viewport, which would
     read like two separate numbers. */
  .ci {
    color: var(--fg-muted);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    margin-left: 4px;
    white-space: nowrap;
  }
  code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85rem;
  }
  .empty-state {
    color: var(--fg-muted);
    font-style: italic;
  }
  .chart-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .chart-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
  }
  .chart-card canvas { max-width: 100%; height: 220px !important; }
  .heatmap {
    display: inline-grid;
    gap: 2px;
    background: var(--border);
    padding: 2px;
    border-radius: 4px;
  }
  .heatmap-cell {
    width: 56px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-variant-numeric: tabular-nums;
    color: #fff;
    text-shadow: 0 1px 1px rgba(0,0,0,0.25);
  }
  .heatmap-cell.empty {
    background: var(--heat-none);
    color: var(--fg-muted);
    text-shadow: none;
  }
  .heatmap-row { display: contents; }
  .heatmap-wrapper { overflow-x: auto; }
  .heatmap-block { margin-bottom: 24px; }
  .axis-labels {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px;
    margin-top: 8px;
  }
  details { margin-top: 12px; }
  summary {
    cursor: pointer;
    font-weight: 600;
    padding: 4px 0;
  }
  /* Polish: rollout MP4 video recording. Each video element is sized
     to thumbnail width (240px) so the failure-clusters table stays
     scannable. ``preload="metadata"`` keeps the page lightweight —
     the browser fetches just the MP4 header until the user clicks
     play. ``muted`` is required to autoplay-on-hover in some
     browsers; we leave autoplay off here so the user is in charge. */
  .video-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .video-list video {
    width: 240px;
    max-width: 100%;
    border-radius: 4px;
    background: #000;
  }
  .video-empty {
    color: var(--fg-muted);
    font-style: italic;
    font-size: 0.85rem;
  }
</style>
</head>
<body>

<h1>Gauntlet report — {{ report.suite_name }}</h1>

{# ─── 1. Summary card ───
   Per §6 the failure rate is the headline. Overall success appears
   later (in the per-axis section); it is NEVER above the failure
   cluster table. #}
<section>
  <div class="card summary">
    <div class="summary-dot {{ 'pass' if report.overall_failure_rate == 0.0 else ('warn' if report.overall_failure_rate < 0.2 else 'fail') }}"
         title="pass/fail indicator"></div>
    <div class="summary-metrics">
      <div>
        <div class="metric-label">Failure rate</div>
        <div class="metric-value fail">{{ '%.1f'|format(report.overall_failure_rate * 100) }}%</div>
      </div>
      <div>
        <div class="metric-label">Episodes</div>
        <div class="metric-value">{{ report.n_episodes }}</div>
      </div>
      <div>
        <div class="metric-label">Suite</div>
        <div class="metric-value" style="font-size:1.05rem">{{ report.suite_name }}</div>
      </div>
      {# B-30: success-but-unsafe complement. Surfaces the Safety-
         Gymnasium / safe-control-gym framing — a "successful" pick
         that dings the table on every rollout is not actually a
         successful policy. Rendered only when at least one episode
         in the dataset carried safety telemetry (i.e. a MuJoCo run);
         non-MuJoCo reports stay visually identical. #}
      {% if report.success_safe_rate is not none %}
      <div>
        <div class="metric-label">Success unsafe</div>
        <div class="metric-value{% if report.success_safe_rate < 1.0 %} fail{% endif %}">
          {{ '%.1f'|format((1.0 - report.success_safe_rate) * 100) }}%
        </div>
      </div>
      {% endif %}
    </div>
  </div>
</section>

{# ─── 2. Failure clusters — leads the report, per §6 ─── #}
{# When ANY cluster has at least one ``video_paths`` entry, we render
   a "Failed-rollout videos" column (Polish "rollout MP4 video
   recording" feature). The column is suppressed entirely when no
   cluster carries video — keeps the no-video report visually
   identical to the pre-PR layout. #}
{% set any_cluster_video = report.failure_clusters
   and report.failure_clusters | selectattr('video_paths') | list | length > 0 %}
{# B-21: render the actuator-cost column only when at least one
   cluster carries telemetry (i.e. a MuJoCo run). Same conditional-
   column pattern as the videos column above — keeps the no-telemetry
   report visually identical to the pre-PR layout. #}
{% set any_cluster_energy = report.failure_clusters
   and report.failure_clusters
   | rejectattr('mean_actuator_energy', 'none')
   | list | length > 0 %}
{# B-18: render the action-consistency column only when at least one
   cluster carries the mode-collapse measurement (i.e. a sampleable
   policy run with --measure-action-consistency). Mirrors the
   actuator-energy conditional-column pattern above. #}
{% set any_cluster_action_var = report.failure_clusters
   and report.failure_clusters
   | rejectattr('mean_action_variance', 'none')
   | list | length > 0 %}
{# B-30: render the safety-violations column only when at least one
   cluster carries collision OR joint-excursion telemetry (i.e. a
   MuJoCo run). Mirrors the actuator-energy / action-variance
   conditional-column pattern so non-MuJoCo reports stay visually
   identical. #}
{% set any_cluster_safety = report.failure_clusters
   and (
     (report.failure_clusters | rejectattr('mean_collisions', 'none') | list | length > 0)
     or (report.failure_clusters | rejectattr('mean_joint_excursions', 'none') | list | length > 0)
   ) %}
{# B-02: render the behavioural-metrics columns only when at least one
   cluster carries any of the five RoboEval-style trajectory / contact
   metrics (i.e. a MuJoCo run). Two grouped columns keep the table at
   a manageable visual width: time/path/jerk first (trajectory shape),
   then near-collision/peak-force (contact intensity). Mirrors the
   actuator-energy / safety conditional-column pattern so non-MuJoCo
   reports stay visually identical. #}
{% set any_cluster_behavior_traj = report.failure_clusters
   and (
     (report.failure_clusters | rejectattr('mean_time_to_success', 'none') | list | length > 0)
     or (report.failure_clusters | rejectattr('mean_path_length_ratio', 'none') | list | length > 0)
     or (report.failure_clusters | rejectattr('mean_jerk_rms', 'none') | list | length > 0)
   ) %}
{% set any_cluster_behavior_contact = report.failure_clusters
   and (
     (report.failure_clusters | rejectattr('mean_near_collision_count', 'none') | list | length > 0)
     or (report.failure_clusters | rejectattr('mean_peak_force', 'none') | list | length > 0)
   ) %}
<section>
  <h2>Where it failed</h2>
  {% if report.failure_clusters %}
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Axis combination</th>
          <th class="num">n</th>
          {# B-03: header still says "Failure rate" — the cell now
             carries the rate AND the Wilson 95% CI bracket inline, so
             the column meaning has not actually shifted. Adding "[95%
             CI]" to the header would be redundant for an audience the
             PRODUCT.md "expert confidence" rule says we trust. #}
          <th class="num">Failure rate</th>
          <th class="num">Lift (×)</th>
          {% if any_cluster_energy %}<th class="num">Energy / peak τ</th>{% endif %}
          {% if any_cluster_action_var %}<th class="num">Action var (B-18)</th>{% endif %}
          {% if any_cluster_safety %}<th class="num">Collisions / jnt excursions</th>{% endif %}
          {% if any_cluster_behavior_traj %}<th class="num">Time / path / jerk (B-02)</th>{% endif %}
          {% if any_cluster_behavior_contact %}<th class="num">Near coll. / peak force (B-02)</th>{% endif %}
          {% if any_cluster_video %}<th>Failed-rollout videos</th>{% endif %}
        </tr>
      </thead>
      <tbody>
        {% for cluster in report.failure_clusters %}
        <tr>
          <td>
            <code>
              {%- set pairs = [] -%}
              {%- for axis_name, axis_value in cluster.axes.items() -%}
                {{- '' if loop.first else ' ∧ ' -}}
                {{- axis_name }}={{ axis_value -}}
              {%- endfor -%}
            </code>
          </td>
          <td class="num">{{ cluster.n_episodes }}</td>
          <td class="num">
            {{- '%.2f'|format(cluster.failure_rate) -}}
            {%- if cluster.ci_low is not none and cluster.ci_high is not none %}
            <span class="ci">[{{ '%.2f'|format(cluster.ci_low) }}, {{ '%.2f'|format(cluster.ci_high) }}]</span>
            {%- endif %}
          </td>
          <td class="num">{{ '%.2f'|format(cluster.lift) }}×</td>
          {% if any_cluster_energy %}
          {# B-21: tabular nums in the existing ``num`` class so the
             column is right-aligned and digit-stable. ``-`` for
             missing telemetry rather than ``0.00`` — a backend that
             does not surface torque is not the same as a policy that
             commands zero. #}
          <td class="num">
            {%- if cluster.mean_actuator_energy is not none -%}
              {{ '%.3f'|format(cluster.mean_actuator_energy) }}
            {%- else -%}
              <span class="ci">-</span>
            {%- endif -%}
            {% if cluster.mean_peak_torque_norm is not none %}
            <span class="ci">/ {{ '%.2f'|format(cluster.mean_peak_torque_norm) }}</span>
            {% else %}
            <span class="ci">/ -</span>
            {% endif %}
          </td>
          {% endif %}
          {% if any_cluster_action_var %}
          {# B-18: action-mode-collapse metric. ``-`` for greedy
             policies (no SamplablePolicy support) and for runs that
             did not opt into --measure-action-consistency; never
             ``0.00`` (which would mean true mode collapse). #}
          <td class="num">
            {%- if cluster.mean_action_variance is not none -%}
              {{ '%.4f'|format(cluster.mean_action_variance) }}
            {%- else -%}
              <span class="ci">-</span>
            {%- endif -%}
          </td>
          {% endif %}
          {% if any_cluster_safety %}
          {# B-30: per-cluster safety violations. Non-MuJoCo backends
             leave the fields ``None`` and we render ``-``; never
             ``0.00`` (which would mean "every episode in this cluster
             measured zero violations"). Cross-backend semantics
             differ — anti-feature documented on the Episode field. #}
          <td class="num">
            {%- if cluster.mean_collisions is not none -%}
              {{ '%.2f'|format(cluster.mean_collisions) }}
            {%- else -%}
              <span class="ci">-</span>
            {%- endif -%}
            {% if cluster.mean_joint_excursions is not none %}
            <span class="ci">/ {{ '%.2f'|format(cluster.mean_joint_excursions) }}</span>
            {% else %}
            <span class="ci">/ -</span>
            {% endif %}
          </td>
          {% endif %}
          {% if any_cluster_behavior_traj %}
          {# B-02: trajectory-shape behavioural metrics. ``-`` for
             non-MuJoCo backends (cross-backend anti-feature) and for
             cluster-empty values (e.g. all-failure clusters report
             ``-`` on time_to_success because failed rollouts have
             nothing to time to). ``data-sort-value`` carries the raw
             value for a future client-side sort pass; ``-1`` is the
             "missing" sentinel because every metric is non-negative.
             Render order — time / path / jerk — matches the table
             header. #}
          <td class="num" data-sort-value="{{ cluster.mean_time_to_success if cluster.mean_time_to_success is not none else -1 }}">
            {%- if cluster.mean_time_to_success is not none -%}
              {{ '%.2f'|format(cluster.mean_time_to_success) }}s
            {%- else -%}
              <span class="ci">-</span>
            {%- endif -%}
            {% if cluster.mean_path_length_ratio is not none %}
            <span class="ci">/ {{ '%.2f'|format(cluster.mean_path_length_ratio) }}×</span>
            {% else %}
            <span class="ci">/ -</span>
            {% endif %}
            {% if cluster.mean_jerk_rms is not none %}
            <span class="ci">/ {{ '%.1f'|format(cluster.mean_jerk_rms) }}</span>
            {% else %}
            <span class="ci">/ -</span>
            {% endif %}
          </td>
          {% endif %}
          {% if any_cluster_behavior_contact %}
          {# B-02: contact-intensity behavioural metrics. Same ``-``
             convention as the trajectory column above; the
             ``data-sort-value`` carries near_collision_count (the
             count is the dominant signal — peak_force often co-
             varies but is more sensitive to a single contact event). #}
          <td class="num" data-sort-value="{{ cluster.mean_near_collision_count if cluster.mean_near_collision_count is not none else -1 }}">
            {%- if cluster.mean_near_collision_count is not none -%}
              {{ '%.1f'|format(cluster.mean_near_collision_count) }}
            {%- else -%}
              <span class="ci">-</span>
            {%- endif -%}
            {% if cluster.mean_peak_force is not none %}
            <span class="ci">/ {{ '%.2f'|format(cluster.mean_peak_force) }}N</span>
            {% else %}
            <span class="ci">/ -</span>
            {% endif %}
          </td>
          {% endif %}
          {% if any_cluster_video %}
          <td>
            {% if cluster.video_paths %}
            <div class="video-list">
              {% for path in cluster.video_paths %}
              <video controls preload="metadata" muted>
                <source src="{{ path }}" type="video/mp4">
              </video>
              {% endfor %}
            </div>
            {% else %}
            <span class="video-empty">no video</span>
            {% endif %}
          </td>
          {% endif %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="card empty-state">
    No statistically significant failure clusters detected at this threshold.
  </div>
  {% endif %}
</section>

{# ─── 2a. Calibration-aware abstention scoring (B-04) ───
   "Did the policy know it was failing?" — selective-prediction
   numbers over the B-01 conformal failure detector. Rendered only
   when at least one episode in the dataset carried a populated
   ``failure_score`` (i.e. the conformal detector ran upstream); a
   greedy-policy report stays visually identical to pre-B-04. Sits
   right under the failure-clusters table because the two sections
   answer the same question from opposite sides — clusters say
   *where* the policy fails, abstention says *whether the policy
   knew it was about to*. #}
{% if report.abstention_metrics is not none %}
{%- set _ab = report.abstention_metrics -%}
<section>
  <h2>Abstention scoring</h2>
  <p class="subtle">
    Selective-prediction metrics over the B-01 conformal failure
    detector ({{ _ab.n_with_score }} of {{ report.n_episodes }} episodes scored).
    AURC is the area under the coverage-accuracy curve — higher is better;
    perfect detector ≈ 1.0, useless detector ≈ overall success rate.
  </p>
  <div class="card">
    <div class="summary-metrics">
      <div>
        <div class="metric-label">AURC</div>
        <div class="metric-value">{{ '%.3f'|format(_ab.aurc) }}</div>
      </div>
      <div>
        <div class="metric-label">Corrected success rate</div>
        <div class="metric-value">
          {%- if _ab.abstention_corrected_success_rate is not none -%}
            {{ '%.1f'|format(_ab.abstention_corrected_success_rate * 100) }}%
          {%- else -%}
            <span class="ci">-</span>
          {%- endif -%}
        </div>
      </div>
      <div>
        <div class="metric-label">Correctly abstained</div>
        <div class="metric-value">{{ _ab.n_correctly_abstained }}</div>
      </div>
      <div>
        <div class="metric-label">Falsely abstained</div>
        <div class="metric-value{% if _ab.n_falsely_abstained > 0 %} fail{% endif %}">
          {{ _ab.n_falsely_abstained }}
        </div>
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ─── 2b. Per-axis Sobol sensitivity bar (B-19) ───
   "Which axis matters most" — single horizontal bar of total-order
   indices, sorted descending. Sits above the per-axis success-rate
   strip so the reader sees the *ranking* before the rate-per-bucket
   detail. Bar colour is Hairline chrome (NOT the pass/fail palette —
   DESIGN.md Two-System Rule: chrome and semantic vocabularies never
   blend). When ``approximate`` is set (any non-Sobol suite) the
   subtitle warns the indices are an indicator, not a calibrated
   estimate. #}
{% if report.sensitivity_indices %}
{%- set _idx_list = report.sensitivity_indices.values() | list -%}
{%- set _approx = _idx_list and _idx_list[0].approximate -%}
<section>
  <h2>Per-axis sensitivity (Sobol)</h2>
  {% if _approx %}
  <p class="subtle">Approximate — suite sampling is cartesian, not Sobol-quasi-MC.</p>
  {% endif %}
  <div class="chart-card" style="max-width:640px">
    <canvas id="sobol-sensitivity"></canvas>
  </div>
</section>
{% endif %}

{# ─── 3. Per-axis bar charts ─── #}
<section>
  <h2>Per-axis success rate</h2>
  <p class="subtle">
    Overall pass rate: {{ '%.1f'|format(report.overall_success_rate * 100) }}%
    ({{ report.n_success }}/{{ report.n_episodes }} episodes)
  </p>
  {% if report.per_axis %}
  <div class="chart-row">
    {% for axis in report.per_axis %}
    <div class="chart-card">
      <h3>{{ axis.name }}</h3>
      <canvas id="axis-{{ axis.name }}"></canvas>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="card empty-state">No axes present in this report.</div>
  {% endif %}
</section>

{# ─── 4. Per-cell 2D heatmaps ─── #}
{% if report.heatmap_2d %}
<section>
  <h2>Axis-pair heatmaps</h2>
  {% for key, heat in report.heatmap_2d.items() %}
  <div class="heatmap-block card">
    <h3>{{ heat.axis_x }} × {{ heat.axis_y }}</h3>
    <div class="heatmap-wrapper">
      <table>
        <thead>
          <tr>
            <th>{{ heat.axis_y }} \ {{ heat.axis_x }}</th>
            {% for xv in heat.x_values %}<th class="num">{{ xv }}</th>{% endfor %}
          </tr>
        </thead>
        <tbody data-heatmap-key="{{ key }}">
          {% for yv in heat.y_values %}
          <tr>
            <th>{{ yv }}</th>
            {% for xv in heat.x_values %}
            {# Cell content + colour are filled by JS at load time —
               see the renderHeatmaps() block below. The placeholder
               em-dash keeps the rendered HTML readable even with JS
               disabled. The ``title`` carries the axis combination
               for screen readers — the visual percentage label loses
               WCAG AA text contrast at mid-band cells (DESIGN.md §4
               Heatmap Contrast Exception); the ``title`` makes the
               data lossless regardless. JS overwrites with the rate
               + percent at load time. #}
            <td class="heatmap-js-cell num"
                title="{{ heat.axis_y }}={{ yv }} × {{ heat.axis_x }}={{ xv }}">—</td>
            {% endfor %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endfor %}
</section>
{% endif %}

{# ─── 5. Per-cell wall-of-numbers (collapsed by §6) ─── #}
{# Same conditional-column pattern as the failure-clusters table: when
   ANY per-cell row carries video, render an extra column; otherwise
   the table is byte-identical to pre-PR for backwards-compat tests. #}
{% set any_cell_video = report.per_cell
   and report.per_cell | selectattr('video_paths') | list | length > 0 %}
<section>
  <details>
    <summary>Per-cell breakdown ({{ report.per_cell|length }} cells) — expand for the full table</summary>
    <div class="card" style="margin-top:8px">
      <table>
        <thead>
          <tr>
            <th class="num">cell</th>
            <th>Perturbation config</th>
            <th class="num">n</th>
            <th class="num">Success rate</th>
            {% if any_cell_video %}<th>Rollout videos</th>{% endif %}
          </tr>
        </thead>
        <tbody>
          {% for cell in report.per_cell %}
          <tr>
            <td class="num">{{ cell.cell_index }}</td>
            <td>
              <code>
                {%- for k, v in cell.perturbation_config.items() -%}
                  {{- '' if loop.first else ', ' -}}
                  {{- k }}={{ v -}}
                {%- endfor -%}
              </code>
            </td>
            <td class="num">{{ cell.n_episodes }}</td>
            <td class="num">
              {{- '%.2f'|format(cell.success_rate) -}}
              {%- if cell.ci_low is not none and cell.ci_high is not none %}
              <span class="ci">[{{ '%.2f'|format(cell.ci_low) }}, {{ '%.2f'|format(cell.ci_high) }}]</span>
              {%- endif %}
            </td>
            {% if any_cell_video %}
            <td>
              {% if cell.video_paths %}
              <div class="video-list">
                {% for path in cell.video_paths %}
                <video controls preload="metadata" muted>
                  <source src="{{ path }}" type="video/mp4">
                </video>
                {% endfor %}
              </div>
              {% else %}
              <span class="video-empty">no video</span>
              {% endif %}
            </td>
            {% endif %}
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </details>
</section>

{#
  Embed the full Report as JSON. NaNs have already been replaced with
  nulls in Python (see gauntlet.report.html._nan_to_none) so this block
  is always valid JSON. Float dict keys become strings under
  model_dump(mode="json"); the JS below runs parseFloat() on them.
#}
<script id="report-data" type="application/json">{{ data|tojson }}</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
(function () {
  const raw = document.getElementById('report-data').textContent;
  const data = JSON.parse(raw);

  // Diverging green→red scale, with gray for null (no data).
  function heatColor(rate) {
    if (rate === null || rate === undefined) return '#d0d0d0';
    // rate in [0,1]; 1.0 = green, 0.0 = red.
    const r = Math.round(214 + (44 - 214) * rate);
    const g = Math.round(39 + (160 - 39) * rate);
    const b = Math.round(40 + (44 - 40) * rate);
    return 'rgb(' + r + ',' + g + ',' + b + ')';
  }

  function renderAxisCharts() {
    (data.per_axis || []).forEach(function (axis) {
      const canvas = document.getElementById('axis-' + axis.name);
      if (!canvas) return;
      // Keys are strings in JSON mode; sort numerically.
      const keys = Object.keys(axis.rates)
        .map(function (k) { return parseFloat(k); })
        .sort(function (a, b) { return a - b; });
      const labels = keys.map(function (k) { return String(k); });
      const rates = keys.map(function (k) { return axis.rates[String(k)]; });
      const counts = keys.map(function (k) { return axis.counts[String(k)]; });
      // B-03: Wilson 95% CI per axis bucket. Optional — older
      // report.json files written before B-03 lack these dicts; the
      // tooltip falls back to no-CI in that case.
      const ciLow = axis.ci_low || {};
      const ciHigh = axis.ci_high || {};
      new Chart(canvas, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [{
            label: 'Success rate',
            data: rates,
            backgroundColor: rates.map(function (r) { return heatColor(r); }),
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: { y: { min: 0, max: 1, ticks: { callback: function (v) { return (v * 100) + '%'; } } } },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function (ctx) {
                  const i = ctx.dataIndex;
                  const k = String(keys[i]);
                  const lo = ciLow[k];
                  const hi = ciHigh[k];
                  const base = 'rate=' + rates[i].toFixed(2) + '  n=' + counts[i];
                  if (lo !== undefined && lo !== null && hi !== undefined && hi !== null) {
                    return base + '  95% CI [' + lo.toFixed(2) + ', ' + hi.toFixed(2) + ']';
                  }
                  return base;
                }
              }
            }
          }
        }
      });
    });
  }

  function renderHeatmaps() {
    const heatmaps = data.heatmap_2d || {};
    document.querySelectorAll('tbody[data-heatmap-key]').forEach(function (tbody) {
      const key = tbody.getAttribute('data-heatmap-key');
      const h = heatmaps[key];
      if (!h) return;
      const rows = tbody.querySelectorAll('tr');
      rows.forEach(function (tr, yIdx) {
        const cells = tr.querySelectorAll('td.heatmap-js-cell');
        cells.forEach(function (td, xIdx) {
          const rate = (h.success_rate[yIdx] || [])[xIdx];
          // Build the SR-alt prefix from the axis pair for this cell.
          // The visual percentage label loses WCAG AA text contrast at
          // mid-band cells (DESIGN.md §4 Heatmap Contrast Exception);
          // the title makes the data lossless regardless. Overwrites
          // the Jinja-side placeholder title that only carries the
          // axis combination.
          const xv = h.x_values[xIdx];
          const yv = h.y_values[yIdx];
          const prefix = h.axis_y + '=' + yv + ' × ' + h.axis_x + '=' + xv;
          if (rate === null || rate === undefined) {
            td.textContent = '—';
            td.style.background = '#d0d0d0';
            td.style.color = '#555';
            td.title = prefix + ': no data';
          } else {
            td.textContent = (rate * 100).toFixed(0) + '%';
            td.style.background = heatColor(rate);
            td.style.color = '#fff';
            td.title = prefix + ': ' + (rate * 100).toFixed(1) + '% success';
          }
        });
      });
    });
  }

  function renderSobol() {
    // B-19: horizontal bar of total-order Sobol indices per axis,
    // sorted descending. Hairline chrome bar (DESIGN.md Two-System
    // Rule — never the pass/fail palette here). ``null`` indices
    // (Var(Y) == 0 on all-success / all-fail runs) are skipped.
    const canvas = document.getElementById('sobol-sensitivity');
    if (!canvas) return;
    const indices = data.sensitivity_indices || {};
    const rows = Object.keys(indices)
      .map(function (k) {
        const ent = indices[k];
        return {
          name: k,
          first: ent.first_order,
          total: ent.total_order,
        };
      })
      .filter(function (r) { return r.total !== null && r.total !== undefined; })
      .sort(function (a, b) { return b.total - a.total; });
    if (rows.length === 0) return;
    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: rows.map(function (r) { return r.name; }),
        datasets: [{
          label: 'Total-order Sobol index',
          data: rows.map(function (r) { return r.total; }),
          backgroundColor: '#e1e1e1',
          borderColor: '#555',
          borderWidth: 1
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        scales: { x: { min: 0, max: 1 } },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function (ctx) {
                const r = rows[ctx.dataIndex];
                const first = (r.first === null || r.first === undefined)
                  ? 'n/a'
                  : r.first.toFixed(3);
                return 'S_T=' + r.total.toFixed(3) + '  S=' + first;
              }
            }
          }
        }
      }
    });
  }

  renderAxisCharts();
  renderHeatmaps();
  renderSobol();
})();
</script>

</body>
</html>
