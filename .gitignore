# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
venv/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# IDE / editor
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Gauntlet artifacts (results, generated reports)
out/
results/
*.results.json

# Phase 2.5 T12 performance-benchmark sidecars. The scripts under
# scripts/perf/bench_*.py default to writing under benchmarks/*.json;
# the scripts and the docs are checked in, the actual numbers are not.
benchmarks/*.json

# Drift-detector artefacts (trajectory dumps, AE weights).
# Test runs produce these under tmp paths but also land in ad-hoc local
# directories when users follow the quickstart; never commit them.
*.npz
*.pt
*.pth
*.safetensors

# Local agent tooling (runtime state, never project code).
# Contributors using per-developer agent tooling should prefer adding
# these to their user-global gitignore (~/.config/git/ignore) — the
# project does not care which tool you use.
*.vector.db
.swarm/
.mcp.json
